rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isCoupleMember(coupleId) {
      return exists(/databases/$(database)/documents/couples/$(coupleId)) &&
        (
          get(/databases/$(database)/documents/couples/$(coupleId)).data.userA == request.auth.uid ||
          get(/databases/$(database)/documents/couples/$(coupleId)).data.userB == request.auth.uid
        );
    }

    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /couples/{coupleId} {
      allow read: if isCoupleMember(coupleId);
      allow write: if request.auth.uid in [request.resource.data.userA, request.resource.data.userB];
    }

    match /signals/{signalId} {
      allow create: if isCoupleMember(request.resource.data.coupleId)
        && request.resource.data.senderId == request.auth.uid;
      allow read, update, delete: if isCoupleMember(resource.data.coupleId);
    }
  }
}
