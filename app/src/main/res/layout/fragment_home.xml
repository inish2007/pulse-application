<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_aurora_gradient"
    android:clipToPadding="false"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:paddingBottom="100dp">

        <!-- Top Header: Greeting -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Together Today"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Partner connection status card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_partner_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_partner_avatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/love_pink"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_partner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partner"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="@id/iv_partner_avatar"
                app:layout_constraintBottom_toTopOf="@id/tv_connection_status"
                app:layout_constraintStart_toEndOf="@id/iv_partner_avatar"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connected"
                android:textColor="@color/md_theme_status_green"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_partner_name"
                app:layout_constraintBottom_toBottomOf="@id/iv_partner_avatar"
                app:layout_constraintStart_toEndOf="@id/iv_partner_avatar" />

            <!-- Active indicator dot -->
            <View
                android:id="@+id/v_status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot"
                android:backgroundTint="@color/md_theme_status_green"
                android:layout_marginEnd="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Stats row: Streak & Anniversary (Coming Soon) -->
        <LinearLayout
            android:id="@+id/row_quick_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/card_partner_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Streak Card (Coming Soon) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_streak"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_streak"
                    app:tint="@color/md_theme_accent"
                    android:alpha="0.5"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_streak_coming_soon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coming Soon"
                    android:textColor="@color/voile_purple"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_status_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Love Streak"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:alpha="0.5"
                    app:layout_constraintTop_toBottomOf="@id/iv_streak"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Feature"
                    android:textColor="@color/md_theme_accent"
                    android:textSize="12sp"
                    android:alpha="0.5"
                    app:layout_constraintTop_toBottomOf="@id/tv_streak_count"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Anniversary Card (Coming Soon) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_anniversary"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_heart"
                    app:tint="@color/md_theme_accent"
                    android:alpha="0.5"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_anniversary_coming_soon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Coming Soon"
                    android:textColor="@color/voile_purple"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_status_pill"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_anniversary_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anniversary"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:alpha="0.5"
                    app:layout_constraintTop_toBottomOf="@id/iv_anniversary"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium Feature"
                    android:textColor="@color/md_theme_accent"
                    android:textSize="12sp"
                    android:alpha="0.5"
                    app:layout_constraintTop_toBottomOf="@id/tv_anniversary_days"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <!-- Daily Quote Card (Coming Soon) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/row_quick_stats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_quote_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quote"
                app:tint="@color/md_theme_accent"
                android:alpha="0.5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Quote (Coming Soon)"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:alpha="0.5"
                app:layout_constraintTop_toTopOf="@id/iv_quote_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_quote_icon"
                app:layout_constraintStart_toEndOf="@id/iv_quote_icon" />

            <TextView
                android:id="@+id/tv_quote_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Premium members will receive daily relationship quotes and insights here."
                android:textColor="@color/md_theme_accent"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif"
                app:layout_constraintTop_toBottomOf="@id/iv_quote_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Quick signals shortcuts card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_shortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/card_quote"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_shortcuts_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Signals"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toBottomOf="@id/tv_shortcuts_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Quick Love Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_love"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Quick Send Love"
                    android:layout_marginHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️"
                        android:textSize="24sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Hug Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_hug"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Quick Send Hug"
                    android:layout_marginHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤗"
                        android:textSize="24sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Kiss Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_kiss"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Quick Send Kiss"
                    android:layout_marginHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💋"
                        android:textSize="24sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Angry Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_angry"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Quick Send Angry"
                    android:layout_marginHorizontal="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😤"
                        android:textSize="24sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Recent Activity Header -->
        <TextView
            android:id="@+id/tv_recent_activity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Activity"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_shortcuts"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Recent Activity Empty State Placeholder -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_recent_activity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <ImageView
                android:id="@+id/iv_empty_activity"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_history"
                app:tint="@color/md_theme_accent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No recent signals"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/iv_empty_activity"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your recent interactions will appear here"
                android:textColor="@color/md_theme_accent"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@+id/iv_empty_activity"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="1.0"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
