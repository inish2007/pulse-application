<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp"
    android:clipToPadding="false"
    android:scrollbars="none">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp">

        <!-- Top Header: Greeting -->
        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home /"
            android:textColor="@color/md_theme_accent"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Together Today"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_home_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Partner connection status card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_partner_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_partner_avatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/love_pink"
                android:background="@drawable/bg_glass_card"
                android:padding="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_partner_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partner"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tv_connection_status"
                app:layout_constraintStart_toEndOf="@id/iv_partner_avatar" />

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textColor="@color/md_theme_status_amber"
                android:textSize="14sp"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_partner_name"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/iv_partner_avatar" />

            <!-- Active indicator dot -->
            <View
                android:id="@+id/v_status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot"
                android:layout_marginEnd="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Stats row: Streak & Countdown -->
        <LinearLayout
            android:id="@+id/row_quick_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/card_partner_status"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Streak Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_streak"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_streak"
                    app:tint="@color/coral_peach"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="27 Days"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/iv_streak"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Love Streak"
                    android:textColor="@color/md_theme_accent"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_streak_count"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Anniversary Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_anniversary"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_heart"
                    app:tint="@color/love_pink"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_anniversary_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 Days"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toBottomOf="@id/iv_anniversary"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anniversary"
                    android:textColor="@color/md_theme_accent"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_anniversary_days"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <!-- Daily Quote Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/row_quick_stats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_quote_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_quote"
                app:tint="@color/voile_purple"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily relationship Quote"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toTopOf="@id/iv_quote_icon"
                app:layout_constraintBottom_toBottomOf="@id/iv_quote_icon"
                app:layout_constraintStart_toEndOf="@id/iv_quote_icon" />

            <TextView
                android:id="@+id/tv_quote_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="There are testimonies of relationship waiting for you"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-light"
                app:layout_constraintTop_toBottomOf="@id/iv_quote_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Quick signals shortcuts card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_shortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/card_quote"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_shortcuts_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick signal shortcuts"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tv_shortcuts_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Quick Love Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_love"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❤️"
                        android:textSize="28sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Hug Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_hug"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤗"
                        android:textSize="28sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Kiss Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_kiss"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💋"
                        android:textSize="28sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

                <!-- Quick Angry Button -->
                <FrameLayout
                    android:id="@+id/btn_quick_angry"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_glass_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_margin="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😤"
                        android:textSize="28sp"
                        android:layout_gravity="center"/>
                </FrameLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
