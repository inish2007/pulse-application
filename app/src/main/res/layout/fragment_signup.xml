<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_aurora_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <!-- Logo heart icon -->
        <ImageView
            android:id="@+id/signupLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_heart"
            app:tint="@color/love_pink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/signupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signup_title"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/signupLogo"
            android:layout_marginTop="20dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/signupSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signup_subtitle"
            android:textColor="@color/md_theme_accent"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/signupTitle"
            android:layout_marginTop="4dp" />

        <!-- Glassmorphic input card -->
        <LinearLayout
            android:id="@+id/signupCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/signupSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp">

            <EditText
                android:id="@+id/signupEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/email_hint"
                android:inputType="textEmailAddress"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_accent"
                android:textSize="15sp"
                android:background="@null"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <!-- Thin divider line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/glass_border"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/signupPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/password_hint"
                android:inputType="textPassword"
                android:textColor="@color/md_theme_onSurface"
                android:textColorHint="@color/md_theme_accent"
                android:textSize="15sp"
                android:background="@null"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- Progress bar (preserves original ID) -->
        <ProgressBar
            android:id="@+id/signupProgress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/voile_purple"
            app:layout_constraintTop_toBottomOf="@id/signupCard"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Sign Up button with gradient -->
        <Button
            android:id="@+id/signupButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="@string/signup_cta"
            android:background="@drawable/bg_button_gradient"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@color/md_theme_onPrimary"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toBottomOf="@id/signupCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Toggle to login (preserves original ID) -->
        <TextView
            android:id="@+id/goToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/go_to_login"
            android:textColor="@color/love_pink"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toBottomOf="@id/signupButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
