<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aurora_gradient">

    <!-- Subtle glow orb (decorative) -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:alpha="0.15"
        android:background="@drawable/bg_button_gradient" />

    <!-- Centered content -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- App icon -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_heart"
            android:alpha="0.9"
            app:tint="@color/love_pink"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="16dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subtitle"
            android:textColor="@color/md_theme_accent"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- Loading spinner (preserves original ID) -->
        <ProgressBar
            android:id="@+id/authGateProgress"
            style="?android:attr/progressBarStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="32dp"
            android:indeterminateTint="@color/voile_purple" />

    </LinearLayout>

</FrameLayout>
