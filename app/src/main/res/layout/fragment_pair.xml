<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_aurora_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <!-- Heart icon -->
        <ImageView
            android:id="@+id/heartIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_heart"
            app:tint="@color/love_pink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/pairTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pair_title"
            android:textColor="@color/md_theme_onSurface"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toBottomOf="@id/heartIcon"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/pairSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pair_subtitle"
            android:textColor="@color/md_theme_accent"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/pairTitle"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp" />

        <!-- Your Invite Code card (glassmorphic) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/codeCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/pairSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="28dp">

            <TextView
                android:id="@+id/myCodeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Invite Code:"
                android:textColor="@color/md_theme_accent"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/myCodeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="------"
                android:textColor="@color/love_pink"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toBottomOf="@id/myCodeLabel"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="8dp" />

            <Button
                android:id="@+id/shareButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Share Link"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/md_theme_onPrimary"
                android:backgroundTint="@color/voile_purple"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/glass_border"
            app:layout_constraintTop_toBottomOf="@id/codeCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <!-- Partner code input (glassmorphic) -->
        <EditText
            android:id="@+id/coupleIdField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Enter Partner's Code"
            android:background="@drawable/bg_glass_card"
            android:textColor="@color/md_theme_onSurface"
            android:textColorHint="@color/md_theme_accent"
            android:textSize="15sp"
            android:padding="18dp"
            android:inputType="textCapCharacters"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <!-- Join Partner button with gradient -->
        <Button
            android:id="@+id/joinButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="Join Partner"
            android:background="@drawable/bg_button_gradient"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="@color/md_theme_onPrimary"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintTop_toBottomOf="@id/coupleIdField"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/pairLoading"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/voile_purple"
            app:layout_constraintTop_toBottomOf="@id/joinButton"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp" />

        <!-- Status pill -->
        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_pill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/status_waiting"
            android:textSize="14sp"
            android:textColor="@color/md_theme_accent"
            app:layout_constraintTop_toBottomOf="@id/joinButton"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
