<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/authGateFragment">

    <fragment
        android:id="@+id/authGateFragment"
        android:name="com.pulse.app.ui.AuthGateFragment"
        android:label="AuthGate" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.pulse.app.ui.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_signup"
            app:destination="@id/signupFragment" />
        <action
            android:id="@+id/action_login_to_pair"
            app:destination="@id/pairFragment" />
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.pulse.app.ui.SignupFragment"
        android:label="Signup">
        <action
            android:id="@+id/action_signup_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_signup_to_pair"
            app:destination="@id/pairFragment" />
        <action
            android:id="@+id/action_signup_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/pairFragment"
        android:name="com.pulse.app.ui.PairFragment"
        android:label="Pair">
        <action
            android:id="@+id/action_pair_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.pulse.app.ui.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_signal"
            app:destination="@id/signalFragment" />
        <action
            android:id="@+id/action_home_to_history"
            app:destination="@id/historyFragment" />
        <action
            android:id="@+id/action_home_to_profile"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/signalFragment"
        android:name="com.pulse.app.ui.SignalFragment"
        android:label="Signal" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.pulse.app.ui.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.pulse.app.ui.ProfileFragment"
        android:label="Profile" />
</navigation>

